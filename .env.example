# App
API_TITLE=EmoEdu F1/F4 API
API_VERSION=0.1.0

# Database
# Production example:
# DATABASE_URL=postgresql+asyncpg://emoedu_user:password@localhost:5432/emoedu
DATABASE_URL=postgresql+asyncpg://emoedu_user:password@localhost:5432/emoedu

# LLM
# Use mock for local tests and development without network/API key.
LLM_PROVIDER=mock
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT=10.0
LLM_MAX_TOKENS=1000

# F1 Safety Gate
HISTORY_WINDOW_N=6
SAFETY_LLM_TEMPERATURE=0.0

# F2 Scenario Analysis
SCENARIO_LLM_TEMPERATURE=0.0

# F3 Multi-Orientation Generator
GENERATOR_LLM_TEMPERATURE=0.8

# F4 Critic
CRITIC_LLM_TEMPERATURE=0.1
CRITIC_SAMPLE_COUNT=3
