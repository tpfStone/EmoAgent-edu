# App
API_TITLE=EmoAgent API
API_VERSION=0.1.0

# Database
# Production example:
# DATABASE_URL=postgresql+asyncpg://emoagent_user:password@localhost:5432/emoagent
# Local demo alternative:
# DATABASE_URL=sqlite+aiosqlite:///./local-dev.sqlite
DATABASE_URL=postgresql+asyncpg://emoagent_user:password@localhost:5432/emoagent

# LLM
# Use mock for local tests and development without network/API key.
LLM_PROVIDER=mock
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_THINKING=disabled
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.7-plus
DASHSCOPE_THINKING=disabled
LLM_TIMEOUT=10.0
LLM_MAX_TOKENS=1000

# F1 Safety Gate / Chat runtime
HISTORY_WINDOW_N=6
# Redis is required for full local-live multi-turn history and background F4 guidance.
# If it is unavailable, /chat degrades to no-history single-turn responses.
REDIS_URL=redis://localhost:6379/0
CHAT_HISTORY_TTL_SECONDS=604800
CHAT_STREAM_CHUNK_SIZE=2
CHAT_FALLBACK_MESSAGE=我现在有点没反应过来，要不你再说一次？
F1_SAFETY_MODEL_DIR=exp/models/f1_safety_gate/manual-A-pattern-v1
F1_SAFETY_BERT_MODEL=bert-base-chinese
F1_SAFETY_LOCAL_FILES_ONLY=true
F1_SAFETY_DEVICE=auto
F1_SAFETY_MAX_LENGTH=192
F1_SAFETY_RED_THRESHOLD=0.45
F1_SAFETY_YELLOW_OR_RED_THRESHOLD=0.55
F1_SAFETY_PRELOAD=true
F1_SAFETY_REQUIRED=false
F1_SAFETY_HF_REPO=Nacgisac/EmoEduF1-bert-base-chinese
F1_SAFETY_HF_REVISION=main
SAFETY_LLM_TEMPERATURE=0.0

# F2 Scenario Analysis
SCENARIO_LLM_TEMPERATURE=0.0

# F3 Generator + PsyQA support cards
GENERATOR_LLM_TEMPERATURE=0.8
F3_SUPPORT_ENABLE=true
F3_SUPPORT_PRELOAD=true
F3_PSYQA_LABELLED_PATH=exp/data/psyqa_labelled.json
F3_SUPPORT_TOP_K=2
F3_SUPPORT_MIN_SCORE=0.10

# F4 Critic
CRITIC_DEEPSEEK_MODEL=deepseek-v4-pro
CRITIC_DEEPSEEK_THINKING=enabled
CRITIC_DASHSCOPE_MODEL=qwen3.7-plus
CRITIC_DASHSCOPE_THINKING=disabled
CRITIC_LLM_TIMEOUT=30.0
CRITIC_LLM_MAX_TOKENS=4096
CRITIC_LLM_TEMPERATURE=0.1
CRITIC_LLM_RESPONSE_FORMAT_JSON=true
CRITIC_SAMPLE_COUNT=3
ROUTE_SELECTOR_MIN_WEIGHTED_TOTAL=3.0

# F6 memory/RAG is reserved and disabled by default.
F6_MEMORY_ENABLE=false
F6_MEMORY_PRELOAD=false
F6_MEMORY_PERSIST_DIR=exp/data/vector_store/faiss_memory
F6_MEMORY_EMBEDDING_MODEL=hashing
F6_MEMORY_MINILM_PATH=exp/models/embeddings/all-MiniLM-L6-v2
F6_MEMORY_TOP_K=3
F6_MEMORY_MIN_SCORE=0.15
F6_RAG_CACHE_TTL_SECONDS=900
F6_RAG_CACHE_MAX_ENTRIES=512
F6_RAG_CACHE_SEMANTIC_THRESHOLD=0.9
